pipeline {

    agent any

    stages {

        stage('Clone') {

            steps {

                git branch: 'main', url: 'https://github.com/jmartinezb11-cmd/proyecto-devops-final'

            }

        }

        stage('Build Docker Image') {

            steps {

                sh 'docker build -t proyecto-devops .'

            }

        }

        stage('Deploy Swarm') {

            steps {

                sh 'docker stack deploy -c swarm/docker-stack.yml proyecto'

            }

        }
    }
}
